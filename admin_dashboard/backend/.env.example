# PostgreSQL — Docker için DB_HOST=db olmalı (localhost değil)
DB_NAME=liftup_db
DB_USER=postgres
# Kök .env dosyasındaki POSTGRES_PASSWORD ile aynı değer olmalı
DB_PASSWORD=your_db_password
DB_HOST=db
DB_PORT=5432

# Admin API Güvenlik Anahtarı — aşağıdaki PowerShell komutuyla üret:
# [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
ADMIN_API_KEY=your_secure_api_key_here

# JWT — aşağıdaki PowerShell komutuyla üret:
# [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE_MINUTES=180

# Geçici dosyalar dizini — değiştirme
JOBS_DIR=./jobs

# Maksimum PDF dosya boyutu (MB)
MAX_PDF_SIZE_MB=200

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173
