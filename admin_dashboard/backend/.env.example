# PostgreSQL Bağlantı Bilgileri
DB_NAME=liftup_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Admin API Güvenlik Anahtarı
# Tüm /admin endpoint'lerine istek yaparken X-Admin-Key header'ı olarak gönderilir
ADMIN_API_KEY=your_key

# Geçici dosyalar dizini (PDF işleme sırasında kullanılır)
# Göreceli yol — admin_dashboard/backend/jobs/ olarak oluşturulur
JOBS_DIR=./jobs

# Maksimum PDF dosya boyutu (MB cinsinden)
MAX_PDF_SIZE_MB=200

# CORS — Admin frontend origin'leri
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173
