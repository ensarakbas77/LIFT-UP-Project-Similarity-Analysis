# PostgreSQL Bağlantı Bilgileri (ana backend ile aynı DB)
DB_NAME=liftup_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Admin API Güvenlik Anahtarı
ADMIN_API_KEY=your_secure_api_key_here

# JWT Ayarları
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE_MINUTES=180

# Geçici dosyalar dizini
JOBS_DIR=./jobs

# Maksimum PDF dosya boyutu (MB)
MAX_PDF_SIZE_MB=200

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:5173
