# ── PRODUCTION ORTAMI — AWS RDS + EC2 ────────────────────────────────────────
# Bu dosya EC2 sunucusunda .env.prod olarak oluşturulacaktır:
#   cp .env.prod.example .env.prod

# PostgreSQL — AWS RDS endpoint
DB_NAME=liftup_db
DB_USER=postgres
DB_PASSWORD=your_rds_master_password
DB_HOST=your-rds-endpoint.xxxxxxxxxxxx.eu-central-1.rds.amazonaws.com
DB_PORT=5432
DB_SSLMODE=require

# Admin API Güvenlik Anahtarı — aşağıdaki PowerShell komutuyla üret:
# [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
ADMIN_API_KEY=your_secure_api_key_here

# JWT — aşağıdaki PowerShell komutuyla üret:
# [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE_MINUTES=480

# Geçici dosyalar dizini — değiştirme
JOBS_DIR=./jobs

# Maksimum PDF dosya boyutu (MB)
MAX_PDF_SIZE_MB=200

# CORS — production admin URL'i
CORS_ORIGINS=https://admin.prestigeai.com.tr
