# ─── Kök .env Dosyası ─────────────────────────────────────────────────────────
#
# Bu dosya docker-compose.yml tarafından okunur.
# Kopyalayıp .env olarak kaydet, sonra değerleri doldur:
#
#   Copy-Item .env.example .env
#
# .env dosyası .gitignore'da — asla commit edilmez.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL container şifresi.
# similarity_analysis_app/backend/.env ve admin_dashboard/backend/.env
# içindeki DB_PASSWORD ile AYNI değer olmalı.
POSTGRES_PASSWORD=your_db_password
