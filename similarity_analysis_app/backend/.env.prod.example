# ── PRODUCTION ORTAMI — AWS RDS + EC2 ────────────────────────────────────────
# Bu dosya EC2 sunucusunda .env.prod olarak oluşturulacaktır:
#   cp .env.prod.example .env.prod

# PostgreSQL — AWS RDS endpoint
DB_NAME=liftup_db
DB_USER=postgres
DB_PASSWORD=your_rds_master_password
DB_HOST=your-rds-endpoint.xxxxxxxxxxxx.eu-central-1.rds.amazonaws.com
DB_PORT=5432
DB_SSLMODE=require

# SBERT Model — değiştirme
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
EMRECAN_MODEL_NAME=emrecan/bert-base-turkish-cased-mean-nli-stsb-tr

# Benzerlik Eşikleri — değiştirme
CRITICAL_THRESHOLD=0.90
HIGH_THRESHOLD=0.70
MEDIUM_THRESHOLD=0.50
LOW_THRESHOLD=0.25
DEFAULT_TOP_K=5

# CORS — production frontend URL'leri
CORS_ORIGINS=https://app.prestigeai.com.tr,https://www.prestigeai.com.tr

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite # gemini-2.5-flash
GEMINI_KEYWORD_COUNT=5
