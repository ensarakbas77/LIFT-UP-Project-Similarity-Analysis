# PostgreSQL — Docker için DB_HOST=db olmalı (localhost değil)
DB_NAME=liftup_db
DB_USER=postgres
# Kök .env dosyasındaki POSTGRES_PASSWORD ile aynı değer olmalı
DB_PASSWORD=your_db_password
DB_HOST=db
DB_PORT=5432

# SBERT Model — değiştirme
MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
EMRECAN_MODEL_NAME=emrecan/bert-base-turkish-cased-mean-nli-stsb-tr

# Benzerlik Eşikleri — değiştirme
CRITICAL_THRESHOLD=0.90
HIGH_THRESHOLD=0.70
MEDIUM_THRESHOLD=0.50
LOW_THRESHOLD=0.25
DEFAULT_TOP_K=5

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Gemini API — https://aistudio.google.com adresinden ücretsiz alınır
# Anahtar kelime önerisi özelliği için gerekli, boş bırakılırsa bu özellik çalışmaz
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_KEYWORD_COUNT=5
